# ========================
# 编译产物
# ========================
*.exe
*.dll
*.so
*.dylib
agent/nezha-agent*
agent/agent*
nezha/nezha-dashboard*
nezha/dashboard*

# ========================
# 本地配置（含凭据，不提交）
# ========================
# agent/config.yml 包含 client_secret，仅本地使用
agent/config.yml

# ========================
# 数据与日志
# ========================
data/
*.db
*.db-journal
# 例外：geoip.db 是 go:embed 需要的占位文件，必须提交
!nezha/pkg/geoip/geoip.db
*.log
*.tmp
*.pid
*.sock

# ========================
# 原版源码备份（不提交）
# ========================
source/

# ========================
# 原版前端源码（精简版下载预编译前端，不需要源码）
# ========================
admin-frontend/

# ========================
# 原版子目录中的 GitHub 配置（精简版只用根目录 .github/）
# ========================
nezha/.github/
agent/.github/

# ========================
# 根目录 Markdown（README.md 除外）
# ========================
/*.md
!README.md

# ========================
# Go
# ========================
# 只忽略 Go modules 根目录的 vendor/，不忽略源码中的 vendor 子包（如 agent/pkg/monitor/gpu/vendor/）
/vendor/
*.test
*.out
*.cover
coverage/

# ========================
# 前端
# ========================
node_modules/
*.lock
package-lock.json
yarn.lock
pnpm-lock.yaml
*.map

# ========================
# IDE / 编辑器
# ========================
.vscode/
.idea/
*.swp
*.swo
*.swn
*.bak
*.orig
*~
.DS_Store
Thumbs.db

# ========================
# 临时文件
# ========================
tmp/
temp/
dist/
build/
release/



